# **************************************************************************** #
#                                                                              #
#                                  Git Ignore                                  #
#                                                                              #
# **************************************************************************** #

# Project binaries
minishell
minishell_val

# Object files and build directories
*.o
*.d
obj/
objs/
build/
.build/

# Static libraries generated by dependencies
*.a
libft/libft.a
libft/*.o

# Debug and crash files
core
core.*
vgcore.*
valgrind-out.txt

# Logs and temporary files
*.log
*.tmp
*.temp
*.bak
*.orig
*.rej

# Editor swap/backup files
*~
*.swp
*.swo
*.swn
*.un~

# IDE/editor directories
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
